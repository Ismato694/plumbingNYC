# Copy to .env and fill in your values.

# Google Analytics 4 Measurement ID (used in index.html analytics snippet)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact form endpoint (e.g. Formspree, serverless function).
# Wire this into src/components/ContactForm.tsx where the submit is handled.
VITE_CONTACT_ENDPOINT=https://formspree.io/f/XXXXXXX
